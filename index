    await new Promise(r => setTimeout(r, 750));
    renderProgress('complete', cleaned); // 100% — snaps to full
    await new Promise(r => setTimeout(r, 250));

    // Bucket complaints by year for the trend chart (2021 → current year)
    const currentYear = new Date().getFullYear();
    const CHART_START = 2021;
    const yearBuckets = {};
    for (let y = CHART_START; y <= currentYear; y++) yearBuckets[y] = 0;
    rows.forEach(r => {
      if (!r.created_date) return;
      const y = new Date(r.created_date).getFullYear();
      if (y >= CHART_START && y <= currentYear) yearBuckets[y]++;
    });

    const chartYears = Object.keys(yearBuckets).map(Number);
    const chartMax = Math.max(...Object.values(yearBuckets), 1);
    const chartAvg = perYear; // use the real annualized rate (total ÷ elapsed years), same as the score
    const avgLinePct = Math.min(100, (chartAvg / chartMax) * 100);

    // Find the peak year and its dominant complaint type for the insight sentence
    const peakYear = chartYears.reduce((best, y) => yearBuckets[y] > yearBuckets[best] ? y : best, chartYears[0]);
    const peakCount = yearBuckets[peakYear];
    const peakTypeMap = {};
    rows.forEach(r => {
