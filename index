const GEOSEARCH_AUTOCOMPLETE = 'https://geosearch.planninglabs.nyc/v2/autocomplete';
const GEOSEARCH_SEARCH = 'https://geosearch.planninglabs.nyc/v2/search';

// Reverse-geocode an address string to a neighbourhood name via NYC GeoSearch.
// Returns a string like "Clinton Hill" or null if not found / not available.
async function fetchNeighbourhood(address) {
  const cacheKey = `neighbourhood:${address.toLowerCase().trim()}`;
  try {
    const cached = sessionStorage.getItem(cacheKey);
    if (cached !== null) return cached || null; // empty string means "tried, not found"
  } catch(e) {}

  try {
    const params = new URLSearchParams({ text: address, size: '1' });
    const res = await fetch(`${GEOSEARCH_SEARCH}?${params.toString()}`);
    if (!res.ok) return null;
    const data = await res.json();
    const props = data?.features?.[0]?.properties || {};
    const neighbourhood = props.neighbourhood || props.neighborhood || null;
    try { sessionStorage.setItem(cacheKey, neighbourhood || ''); } catch(e) {}
    return neighbourhood;
  } catch(e) {
    return null;
  }
}
const DEBOUNCE_MS = 150;
const MIN_CHARS = 2;

let debounceTimer = null;
let acAbortController = null;
let currentSuggestions = [];
let highlightedIndex = -1;

const addressInput = document.getElementById('addressInput');
const suggestionsBox = document.getElementById('suggestions');
const searchShell = document.getElementById('searchShell');

const PIN_SVG = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M8 1.5C5.51 1.5 3.5 3.51 3.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.49-2.01-4.5-4.5-4.5z" stroke="#b3ab9c" stroke-width="1.3" fill="none"/>
  <circle cx="8" cy="6" r="1.5" stroke="#b3ab9c" stroke-width="1.3"/>
</svg>`;

function openShell() {
  searchShell.classList.add('open');
  suggestionsBox.classList.add('open');
  if (isMobile() && mobileCta) mobileCta.style.display = 'none';
}

function closeShell() {
  searchShell.classList.remove('open');
  suggestionsBox.classList.remove('open');
  suggestionsBox.innerHTML = '';
  currentSuggestions = [];
  highlightedIndex = -1;
  if (isMobile() && mobileCta && !document.getElementById('heroSection').classList.contains('has-results')) {
    mobileCta.style.display = 'block';
  }
}

function hideSuggestions() { closeShell(); }

function renderSuggestions(features) {
  currentSuggestions = features;
  highlightedIndex = -1;

  if (features.length === 0) {
    suggestionsBox.innerHTML = `<div class="suggestion-divider"></div><div class="suggestion-empty">No matching NYC addresses</div>`;
    openShell();
    return;
  }

  const rows = features.map((f, i) => {
    const props = f.properties || {};
    const main = (props.name || '').toUpperCase();
    const borough = props.borough || props.county || '';
    const sub = borough ? `${borough}, NY, USA` : (props.region || '');
    return `<div class="suggestion-item" data-index="${i}">
      <span class="suggestion-pin">${PIN_SVG}</span>
      <span class="suggestion-text">
        <span class="suggestion-main">${escapeHtml(main)}</span>
        ${sub ? `<span class="suggestion-sub">${escapeHtml(sub)}</span>` : ''}
      </span>
    </div>`;
  }).join('');

  suggestionsBox.innerHTML = `<div class="suggestion-divider"></div>${rows}`;
  openShell();
}

function selectSuggestion(feature) {
  const props = feature.properties || {};
  const chosen = props.name || props.label;
  addressInput.value = chosen;
  closeShell();
  // Pass along borough, state, zip from GeoSearch for the address headline
  const geoMeta = {
    borough: props.borough || props.county || null,
    state: props.region_a || 'NY',
    zip: props.postalcode || null,
  };
  runSearch(chosen, geoMeta);
}

async function fetchSuggestions(text) {
  if (acAbortController) acAbortController.abort();
  acAbortController = new AbortController();
  const params = new URLSearchParams({ text, size: '3' });
  try {
    const res = await fetch(`${GEOSEARCH_AUTOCOMPLETE}?${params.toString()}`, { signal: acAbortController.signal });
    if (!res.ok) throw new Error();
    const data = await res.json();
    renderSuggestions((data.features || []).slice(0, 3));
  } catch (err) {
    if (err.name === 'AbortError') return;
    closeShell();
  }
}

addressInput.addEventListener('input', (e) => {
  const text = e.target.value.trim();
  clearTimeout(debounceTimer);
  if (text.length < MIN_CHARS) { closeShell(); return; }
  debounceTimer = setTimeout(() => fetchSuggestions(text), DEBOUNCE_MS);
});

addressInput.addEventListener('keydown', (e) => {
  const items = suggestionsBox.querySelectorAll('.suggestion-item');
  if (e.key === 'ArrowDown' && items.length) {
    e.preventDefault();
    highlightedIndex = Math.min(highlightedIndex + 1, items.length - 1);
    items.forEach((el, i) => el.classList.toggle('highlighted', i === highlightedIndex));
    return;
  }
  if (e.key === 'ArrowUp' && items.length) {
    e.preventDefault();
    highlightedIndex = Math.max(highlightedIndex - 1, 0);
    items.forEach((el, i) => el.classList.toggle('highlighted', i === highlightedIndex));
    return;
  }
  if (e.key === 'Enter') {
    if (highlightedIndex >= 0 && currentSuggestions[highlightedIndex]) {
      selectSuggestion(currentSuggestions[highlightedIndex]);
    } else {
      closeShell();
      runSearch(e.target.value);
    }
    return;
  }
  if (e.key === 'Escape') closeShell();
});

suggestionsBox.addEventListener('mousedown', (e) => {
  const item = e.target.closest('.suggestion-item');
  if (!item) return;
  const index = parseInt(item.dataset.index, 10);
  if (currentSuggestions[index]) selectSuggestion(currentSuggestions[index]);
});

document.addEventListener('click', (e) => {
  if (!e.target.closest('#searchShell')) closeShell();
});

document.getElementById('searchBtn').addEventListener('click', () => {
  closeShell();
  runSearch(addressInput.value);
});


</script>

</body>
