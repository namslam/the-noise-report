<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Noise Report — NYC noise history by address</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,400;0,500;0,700;0,900;1,400&family=Libre+Franklin:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600&display=swap');

  :root {
    --ink: #15130f;
    --paper: #faf8f2;
    --paper-dim: #f0ebe0;
    --line: #ddd6c8;
    --line-alt: #d8d2c5;
    --accent: #c0392b;
    --body: #3d3a33;
    --muted: #88837a;
    --quiet: #cfc4b2;
    --quiet-bg: #F2F2F2;
    --moderate: #8a8275;
    --moderate-bg: #EBEBEB;
    --loud: #15130f;
    --loud-bg: #E8E8E8;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    overflow-x: hidden;
    max-width: 100%;
    height: 100%;
  }

  body {
    background: var(--paper);
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--ink);
    min-height: 100vh;
  }

  .wrap { max-width: 860px; margin: 0 auto; padding: 0 2rem; overflow-x: hidden; }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-height: 100vh;
    box-sizing: border-box;
    justify-content: flex-start;
    padding-top: calc(50vh - 300px);
    padding-bottom: 80px;
    transition: padding-top 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                min-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero.has-results {
    min-height: unset;
    justify-content: flex-start;
    align-items: center;
    padding-top: 4.5rem;
    margin-top: 0;
  }

  /* Nav bar — shown after search on all screen sizes */
  #mobileNav {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 14px 2rem;
    border-bottom: 1px solid #ddd6c8;
    background: var(--paper);
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    box-sizing: border-box;
  }

  #mobileNav.visible { display: flex !important; }

  .mobile-nav-title {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 700;
    font-size: 1rem;
    color: #15130f;
    cursor: pointer;
  }

  .mobile-nav-new-search {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #15130f;
    background: #fff;
    border: 1px solid #ddd6c8;
    border-radius: 100px;
    padding: 6px 12px;
    cursor: pointer;
  }

  /* Hide hero elements and search bar when nav is showing on desktop */
  .hero.has-results h1,
  .hero.has-results .lede,
  .hero.has-results .hero-eyebrow,
  .hero.has-results .hero-icon-wrap,
  .hero.has-results #searchShell {
    display: none !important;
  }

  h1 {
    margin: 0 0 0;
    transition: opacity 0.35s ease, max-height 0.4s ease;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(2.8rem, 8vw, 3.75rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .hero-icon-wrap {
    display: flex;
    justify-content: flex-start;
    margin: 1.75rem 0 2.25rem;
  }

  .hero-icon {
    width: clamp(7rem, 24vw, 11rem);
    height: auto;
    animation: icon-shake 2.6s ease-in-out infinite;
    transform-origin: 50% 85%;
  }

  @keyframes icon-shake {
    0%, 100% { transform: rotate(0deg); }
    5% { transform: rotate(-2deg); }
    10% { transform: rotate(2deg); }
    15% { transform: rotate(-1.5deg); }
    20% { transform: rotate(1.5deg); }
    25% { transform: rotate(0deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-icon { animation: none; }
  }

  @media (prefers-color-scheme: dark) {
    .hero-icon { filter: invert(1); }
  }


  .lede {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.1875rem;
    color: var(--body);
    line-height: 1.5;
    max-width: 640px;
    margin: 18px 0 40px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 26px;
    width: 100%;
    max-width: 640px;
    transition: opacity 0.35s ease;
  }

  .hero-eyebrow-text {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }

  .hero-eyebrow-rule {
    flex: 1;
    height: 1px;
    background: var(--line-alt);
  }

  .search-row {
    display: block;
    margin: 0 auto;
    position: relative;
    width: 640px;
    max-width: 100%;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 100px;
    overflow: visible;
    text-align: left;
    box-shadow: 0 1px 4px rgba(0,0,0,.05);
    transition: border-color 0.12s, border-radius 0.12s, box-shadow 0.2s;
    z-index: 100;
  }

  .search-row.open {
    border-radius: 24px;
    border-color: var(--ink);
    box-shadow: 0 6px 22px rgba(0,0,0,.1);
  }

  .search-row:focus-within:not(.open) {
    border-color: var(--ink);
    box-shadow: 0 6px 22px rgba(0,0,0,.1);
  }

  .search-input-row {
    display: flex;
    align-items: center;
    padding: 0 8px 0 22px;
    gap: 14px;
    width: 100%;
    box-sizing: border-box;
    border-radius: inherit;
  }

  .search-icon {
    flex: none;
    display: flex;
    align-items: center;
    margin-right: 6px;
    line-height: 0;
  }

  .input-wrap {
    flex: 1;
    position: relative;
  }

  .input-wrap input[type="text"] {
    width: 100%;
    border: none !important;
    border-radius: 0 !important;
    padding: 0.875rem 0.5rem !important;
    background: transparent !important;
    box-shadow: none !important;
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.125rem;
    color: var(--ink);
  }

  .input-wrap input[type="text"]:focus {
    outline: none !important;
    box-shadow: none !important;
  }

  .input-wrap input[type="text"]::placeholder {
    color: var(--muted);
  }

  /* Suggestions float below the input row, absolutely positioned so they
     don't push the input upward */
  .suggestions {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid var(--ink);
    border-radius: 24px;
    overflow: hidden;
    padding-bottom: 8px;
    box-shadow: 0 6px 22px rgba(0,0,0,.1);
    z-index: 200;
  }

  .suggestions.open { display: block; }

  .suggestion-divider {
    height: 1px;
    background: #ece7dc;
    margin: 0 20px 6px;
  }

  .suggestion-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 11px 24px;
    cursor: pointer;
    background: transparent;
    transition: background 0.1s;
  }

  .suggestion-item:hover,
  .suggestion-item.highlighted { background: #f6f2e9; }

  .suggestion-pin {
    flex: none;
    margin-top: 2px;
    line-height: 0;
  }

  .suggestion-text { display: flex; flex-direction: column; gap: 2px; }

  .suggestion-main {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 17px;
    font-weight: 600;
    color: #15130f;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .suggestion-sub {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 12.5px;
    color: #88837a;
    font-weight: 400;
  }

  .suggestion-empty {
    padding: 11px 24px;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 13px;
    color: var(--muted);
  }

  input[type="text"] {
    flex: 1;
    font-family: 'Inter';
    font-size: 1rem;
    padding: 0.85rem 1rem;
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    background: #fff;
    color: var(--ink);
  }

  input[type="text"]:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(20,17,15,0.12);
  }

  button.go {
    font-family: 'Libre Franklin', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 11px 24px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    flex: none;
    margin: 4px;
    letter-spacing: 0.01em;
  }

  button.go:hover { background: #2A2520; }
  button.go:disabled { opacity: 0.5; cursor: default; }

  .state {
    padding: 2.5rem 0;
    text-align: center;
    color: var(--muted);
  }

  .progress-wrap {
    padding: 2rem 0;
    max-width: 600px;
    margin: 0;
    text-align: left;
  }

  .progress-address {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.69rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.9rem;
  }

  .progress-step-label {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  .progress-step-text {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(1.1rem, 2.8vw, 1.5rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.1;
  }

  .progress-step-pct {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 1.4rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    white-space: nowrap;
  }

  .progress-track {
    height: 3px;
    width: 100%;
    background: var(--line);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 1.75rem;
    margin-top: 0.5rem;
  }

  .progress-fill {
    height: 100%;
    background: var(--ink);
    border-radius: 999px;
    transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .progress-steps-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .progress-step-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 1rem;
    color: #ccc5b5;
    transition: color 0.2s;
    font-weight: 400;
  }

  .progress-step-item.done {
    color: var(--ink);
    font-weight: 400;
  }

  .progress-step-time {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #a39d90;
    margin-left: 6px;
    letter-spacing: 0.02em;
  }

  .progress-step-item.active {
    color: var(--ink);
    font-weight: 600;
  }

  /* Spinning loader for active step */
  @keyframes progress-spin {
    to { transform: rotate(360deg); }
  }

  .progress-step-icon {
    width: 16px;
    height: 16px;
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .progress-step-icon.spin svg {
    animation: progress-spin 0.8s linear infinite;
  }

  .progress-eta {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 1.5rem;
    font-style: italic;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }


  /* ---- Noise score header ---- */
  .score-header {
    padding: 36px 40px 28px;
    border-bottom: 1px solid #15130f;
  }

  .score-header-kicker {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #c0392b;
    margin: 0 0 10px;
  }

  .score-header-address {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(14px, 2vw, 28px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: #15130f;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .score-header-address-muted {
    display: block;
    font-weight: 400;
    font-size: clamp(12px, 1.6vw, 22px);
    color: #88837a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .score-header-score-section {
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid #e7e1d4;
  }

  .score-header-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .score-header-label {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 700;
    font-size: 52px;
    letter-spacing: -0.02em;
    color: #15130f;
    line-height: 1;
  }

  .score-track-wrap {
    margin: 24px 0 8px;
    position: relative;
  }

  .score-track-bar {
    height: 6px;
    border-radius: 100px;
    background: linear-gradient(90deg, #dfe7df, #e8c9a8, #d98452, #c0392b);
  }

  .score-track-dot {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #15130f;
    border: 3px solid #faf8f2;
    box-shadow: 0 1px 4px rgba(0,0,0,.25);
  }

  .score-track-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 11.5px;
    color: #a39d90;
  }

  .score-header-sub {
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    color: #88837a;
    margin: 16px 0 0;
    display: block;
  }

  @media (max-width: 600px) {
    .score-header { padding: 20px 20px 18px; }
    .score-header-address { font-size: clamp(12px, 4vw, 20px); white-space: nowrap; }
    .score-header-address-muted { font-size: clamp(11px, 3.5vw, 16px); }
    .score-header-label { font-size: 36px; }
  }

  /* ---- Result card shell ---- */
  /* ====== RESULT CARD ====== */
  .result-card {
    border: 1px solid #15130f;
    border-radius: 14px;
    background: #faf8f2;
    overflow: hidden;
    margin-top: 1.5rem;
    max-width: 860px;
    width: 100%;
  }

  /* Header */
  .result-head {
    padding: 38px 44px 34px;
    border-bottom: 1px solid #15130f;
    text-align: left;
  }

  .matched-address {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #a39d90;
    margin: 0 0 12px;
  }

  .match-label {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #88837a;
    margin: 0 0 12px;
    font-style: italic;
  }

  .match-label--cap-warning {
    color: #a05c2a;
    font-style: normal;
    font-weight: 500;
    background: #fdf3ec;
    border-left: 3px solid #c0392b;
    padding: 6px 10px;
    border-radius: 0 4px 4px 0;
    line-height: 1.5;
  }

  .score-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 14px;
    text-align: left;
  }

  .score-word {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 900;
    font-size: 64px;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: #15130f;
    font-stretch: normal;
  }

  .score-word.quiet,
  .score-word.moderate,
  .score-word.loud { color: #15130f; }

  .score-pct-badge {
    display: inline-flex;
    align-items: center;
    background: #15130f;
    color: #faf8f2;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 7px 14px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .score-sub {
    display: block;
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    color: #88837a;
    margin-top: 14px;
  }

  /* Stat row */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid #15130f;
  }

  .stat {
    background: #faf8f2;
    padding: 24px 20px 24px;
    border-right: 1px solid #ddd6c8;
    text-align: left;
    overflow: hidden;
  }

  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 900;
    font-size: 28px;
    color: #15130f;
    line-height: 1.15;
  }

  .stat-num--date {
    font-size: 28px;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
  }

  .stat-label {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 13px;
    color: #88837a;
    margin-top: 6px;
  }

  /* Accordion */
  .accordion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
    padding: 22px 44px;
    margin: 0;
    border-bottom: 1px solid transparent;
    transition: background 0.15s;
    scroll-margin-top: 60px;
  }

  .accordion-header:hover { background: rgba(0,0,0,0.02); }

  .accordion-header h3,
  .accordion-header h2 {
    margin: 0;
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #15130f;
  }

  .accordion-chevron {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 13px;
    color: #a39d90;
    transition: transform 0.2s ease;
    flex: none;
    margin-left: 1rem;
  }

  .accordion-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .accordion-body.open { max-height: 20000px; }

  .accordion-section { border-bottom: 1px solid #ddd6c8; }
  .accordion-section:last-child { border-bottom: none; }

  .accordion-section.open .accordion-chevron { transform: rotate(180deg); }
  .accordion-section.open .accordion-header { border-bottom-color: #ddd6c8; }

  /* Trend chart */
  .trend-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 156px;
    position: relative;
    margin-bottom: 20px;
    margin-top: 48px;
    overflow: visible;
  }

  .trend-count {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(10px, 1.8vw, 14px);
    font-weight: 700;
    color: #15130f;
    text-align: center;
    line-height: 1;
    width: 100%;
    white-space: nowrap;
    position: absolute;
    bottom: calc(100% + 5px);
    left: 0;
  }

  .trend-insight-block {
    background: #f0ece1;
    border-radius: 8px;
    padding: 16px 20px;
    margin: 0 0 20px;
    text-align: left;
  }

  .trend-insight-label {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c0392b;
    margin: 0 0 6px;
  }

  .trend-insight-text {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 17px;
    color: #3d3a33;
    line-height: 1.45;
    margin: 0;
  }

  .trend-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    flex: 1;
    min-width: 0;
  }

  .trend-bar-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 120px;
    position: relative;
  }


  .trend-bar {
    width: 100%;
    border-radius: 3px 3px 0 0;
    min-height: 2px;
  }

  .trend-bar.quiet    { background: #cfc4b2; }
  .trend-bar.moderate { background: #8a8275; }
  .trend-bar.loud     { background: #15130f; }
  .trend-bar.zero     { background: #e7e1d4; min-height: 3px; }

  .trend-label {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 12px;
    color: #88837a;
    text-align: center;
    white-space: nowrap;
    line-height: 1;
    margin-top: 8px;
  }

  .trend-label.partial { font-style: italic; }

  .trend-avg-line {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: #15130f;
    opacity: 0.15;
    pointer-events: none;
    transform: translateY(50%);
  }

  .trend-legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
