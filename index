// NYC borough SVG paths — styled to match mockup layout
// Manhattan: slim vertical sliver center-left
// Bronx: small-medium upper center-right
// Queens: large right, overlapping Bronx bottom + Brooklyn top
// Brooklyn: medium-large center-bottom
// Staten Island: small isolated lower-left
const BOROUGH_PATHS = {
  'BRONX':         'M 332,28 L 398,22 L 432,44 L 438,88 L 410,114 L 375,120 L 345,104 L 322,80 L 318,50 Z',
  'MANHATTAN':     'M 298,138 L 308,118 L 318,122 L 321,142 L 314,228 L 302,312 L 286,322 L 276,298 L 274,215 L 282,158 Z',
  'QUEENS':        'M 368,112 L 462,88 L 528,128 L 534,230 L 496,278 L 414,292 L 360,260 L 334,208 L 340,155 Z',
  'BROOKLYN':      'M 300,318 L 382,262 L 455,278 L 474,355 L 448,432 L 374,455 L 298,432 L 268,372 Z',
  'STATEN ISLAND': 'M 72,382 L 152,348 L 196,368 L 200,428 L 164,468 L 102,472 L 65,435 Z'
};

// Label positions — Manhattan external to its left (no tick line), others centered
const BOROUGH_LABEL_POS = {
  'BRONX':         { x: 378, y: 72,  external: false },
  'MANHATTAN':     { x: 258, y: 220, external: true },
  'QUEENS':        { x: 434, y: 190, external: false },
