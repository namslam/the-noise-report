async function fetchAndRenderBoroughMap(onComplete) {
  const loading = document.getElementById('bmapLoading');
  const svgWrap = document.getElementById('bmapSvgWrap');
  const rankedList = document.getElementById('bmapRankedList');
  const headline = document.getElementById('bmapHeadline');

  loading.style.display = 'flex';
  rankedList.innerHTML = '';

  // Rolling 12-month cutoff — same logic as address score
  const cutoff = new Date();
  cutoff.setFullYear(cutoff.getFullYear() - 1);
  const cutoffIso = cutoff.toISOString().split('T')[0];

  const base = 'https://data.cityofnewyork.us/resource/erm2-nwe9.json';
  const params = new URLSearchParams({
    '$select': 'borough, count(*) as cnt',
    '$where': `complaint_type like '%Noise%' AND created_date >= '${cutoffIso}' AND borough IS NOT NULL`,
    '$group': 'borough',
    '$limit': '10'
  });

  let data = [];
  try {
    const res = await fetch(`${base}?${params.toString()}`);
    if (!res.ok) throw new Error('API error');
    data = await res.json();
  } catch(e) {
    loading.innerHTML = 'Couldn’t load borough data. NYC Open Data may be temporarily unavailable.';
    return;
  }

  // Build per-capita rates
  const boroughs = data
    .map(r => {
      const key = (r.borough || '').toUpperCase();
      const pop = BOROUGH_POPULATIONS[key];
      if (!pop) return null;
      const cnt = parseInt(r.cnt, 10);
      const rate = Math.round((cnt / pop) * 100000);
      return { key, name: BOROUGH_DISPLAY_NAMES[key] || r.borough, cnt, rate };
    })
    .filter(Boolean)
    .sort((a, b) => b.rate - a.rate);

  if (boroughs.length === 0) {
    loading.innerHTML = 'No borough data found.';
    return;
  }

  // Update headline
  headline.textContent = `${boroughs[0].name} is the loudest`;
  const todayLabel = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  document.getElementById('bmapSubhead').textContent = `How often each borough calls 311 about noise, in the past year from ${todayLabel}.`;

  // Build SVG map
  loading.style.display = 'none';

  const svgEl = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  svgEl.setAttribute('viewBox', '0 0 600 500');
  svgEl.setAttribute('xmlns', 'http://www.w3.org/2000/svg');

  boroughs.forEach((b, rank) => {
    const path = BOROUGH_PATHS[b.key];
    const pos = BOROUGH_LABEL_POS[b.key];
    if (!path || !pos) return;

    const color = boroughColor(rank, boroughs.length);

    // Borough shape
    const pathEl = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    pathEl.setAttribute('d', path);
    pathEl.setAttribute('fill', color);
    pathEl.setAttribute('stroke', '#faf8f2');
    pathEl.setAttribute('stroke-width', '2');
    pathEl.setAttribute('stroke-linejoin', 'round');
    svgEl.appendChild(pathEl);

    // Determine text colors based on position and rank
    const isExternal = pos.external;
    const isDark = rank <= 2; // top 3 loudest get white text (dark shapes)
    const nameFill  = isExternal ? '#15130f' : (isDark ? '#ffffff' : '#15130f');
    const rateFill  = isExternal ? '#88837a'  : (isDark ? 'rgba(255,255,255,0.75)' : '#88837a');
    const anchor    = isExternal ? 'end' : 'middle';
    const fontSize  = b.key === 'STATEN ISLAND' ? '12' : '14';
    const rateSize  = b.key === 'STATEN ISLAND' ? '11' : '12';
    const nameY     = isExternal ? pos.y - 8  : pos.y - 9;
    const rateY     = isExternal ? pos.y + 10 : pos.y + 9;

    // Borough name
    const nameText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    nameText.setAttribute('x', pos.x);
    nameText.setAttribute('y', nameY);
    nameText.setAttribute('text-anchor', anchor);
    nameText.setAttribute('dominant-baseline', 'middle');
    nameText.setAttribute('font-family', "'Source Serif 4', Georgia, serif");
    nameText.setAttribute('font-weight', '700');
    nameText.setAttribute('font-size', fontSize);
    nameText.setAttribute('fill', nameFill);
    nameText.textContent = b.name;
    svgEl.appendChild(nameText);

    // Rate number below name
    const rateText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    rateText.setAttribute('x', pos.x);
    rateText.setAttribute('y', rateY);
    rateText.setAttribute('text-anchor', anchor);
    rateText.setAttribute('dominant-baseline', 'middle');
    rateText.setAttribute('font-family', "'Libre Franklin', sans-serif");
    rateText.setAttribute('font-weight', '400');
    rateText.setAttribute('font-size', rateSize);
    rateText.setAttribute('fill', rateFill);
    rateText.textContent = b.rate.toLocaleString();
    svgEl.appendChild(rateText);
  });

  // Replace loading spinner with SVG
  svgWrap.innerHTML = '';
  svgWrap.appendChild(svgEl);

  // Build ranked list
  rankedList.innerHTML = boroughs.map((b, i) => `
    <div class="bmap-ranked-item">
      <span class="bmap-rank-num rank-${i + 1}">${i + 1}</span>
      <span class="bmap-rank-name">${b.name}</span>
      <span class="bmap-rank-rate">
        <strong>${b.rate.toLocaleString()}</strong>
        per 100,000 residents
      </span>
    </div>
  `).join('');

  // Scroll to eyebrow now that all content is in the DOM
  if (typeof onComplete === 'function') {
    // Small delay to let the browser paint the new content before measuring
    requestAnimationFrame(() => requestAnimationFrame(onComplete));
  }
}

