<script>
const NOISE_TYPES_LABELS = {
  'Noise - Residential': 'Residential noise',
  'Noise - Street/Sidewalk': 'Street / sidewalk noise',
  'Noise - Commercial': 'Commercial noise',
  'Noise - Vehicle': 'Vehicle noise',
  'Noise - Park': 'Park noise',
  'Noise - House of Worship': 'House of worship noise',
  'Noise': 'General noise',
  'Collection Truck Noise': 'Sanitation truck noise'
};

function labelFor(type) {
  return NOISE_TYPES_LABELS[type] || type;
}

function formatDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// ---- Scoring ----
// Simple, honest flat thresholds based on complaints per year.
// No statistical benchmarks or citywide averages — just a plain scale
// that gives a clear signal without false precision.
//
// Thresholds:
//   0        = No record
//   < 5/yr   = Occasional   (~1 complaint every 2.5+ months)
//   < 20/yr  = Frequent     (~1 complaint every 2.5 weeks – 2.5 months)
//   20+/yr   = Consistently loud (~more than one complaint every 2.5 weeks)
//
// These are judgment calls, not statistical derivations.
// The raw complaints/year figure is always shown so users can judge for themselves.

function scoreFromPerYear(perYear) {
  if (perYear === 0)  return { word: 'Quiet',            cls: 'quiet' }; // zero perYear = genuinely quiet, not no-data
  if (perYear <= 1)   return { word: 'Rare',             cls: 'quiet' };
  if (perYear < 5)    return { word: 'Occasional',       cls: 'quiet' };
  if (perYear < 20)   return { word: 'Frequent',         cls: 'moderate' };
  return                     { word: 'Consistently Loud', cls: 'loud' };
}

function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// Splits "970 Kent Avenue" into { houseNumber: "970", street: "KENT AVENUE" }
// Falls back gracefully if there's no leading number (e.g. just "Bedford Avenue").
function parseAddress(raw) {
  // Normalize curly/smart quotes and apostrophes to straight ASCII equivalents
  const normalized = raw
    .replace(/[‘’ʼ`´]/g, "'")  // curly single quotes → '
    .replace(/[“”]/g, '"');                     // curly double quotes → "
  const cleaned = normalized.trim().replace(/\s+/g, ' ');
  // Match standard house numbers (42, 42A) AND hyphenated Queens-style numbers (27-29, 142-18)
  const match = cleaned.match(/^(\d+(?:-\d+)?[A-Z]?)\s+(.+)$/i);
  if (match) {
    return { houseNumber: match[1].toUpperCase(), street: match[2].toUpperCase(), full: cleaned.toUpperCase() };
  }
  return { houseNumber: null, street: cleaned.toUpperCase(), full: cleaned.toUpperCase() };
}


// Builds a SoQL $where clause as a plain string with real ' and % characters.
// URLSearchParams handles ALL percent-encoding — we never hand-encode here.
function buildWhere(streetLike, houseNumber) {
  // Normalize curly apostrophes before escaping for SoQL
  const normalizedStreet = streetLike.replace(/[‘’ʼ`´]/g, "'");
  const escapedStreet = normalizedStreet.replace(/'/g, "''");
  let clause = `complaint_type like '%Noise%' AND upper(incident_address) like '%${escapedStreet}%'`;
  if (houseNumber) {
    const escapedHouse = houseNumber.replace(/'/g, "''");
    clause += ` AND upper(incident_address) like '${escapedHouse} %'`;
  }
  return clause;
}

// Fetch complaints within a block range (house numbers ± 50 of input)
async function fetchBlockRows(streetLike, houseNumber, limit = 500) {
  const baseNum = parseInt(houseNumber.split('-')[0], 10);
  if (isNaN(baseNum)) return [];
  const lo = Math.max(1, baseNum - 50);
  const hi = baseNum + 50;
  const escapedStreet = streetLike.replace(/'/g, "''");

  // Build a set of server-side LIKE patterns covering the block range.
  // e.g. for 247±50 (197–297): patterns like '1%', '2%' for 3-digit numbers,
  // narrowed to the specific hundreds blocks involved.
  // This dramatically reduces rows returned vs fetching the whole street.
  const loHundred = Math.floor(lo / 100);
  const hiHundred = Math.floor(hi / 100);
  const patterns = [];
  for (let h = loHundred; h <= hiHundred; h++) {
    if (h === 0) {
      // single or double digit addresses (1–99)
      patterns.push(`upper(incident_address) like '% ${escapedStreet}%' AND CAST(split_part(incident_address,' ',1) AS numeric) between ${lo} AND ${hi}`);
    } else {
      patterns.push(`upper(incident_address) like '${h}__ ${escapedStreet}%' OR upper(incident_address) like '${h}_ ${escapedStreet}%' OR upper(incident_address) like '${h} ${escapedStreet}%'`);
    }
  }

  // Simpler fallback: just use a LIKE on the hundreds prefix for each block in range
  const likePatterns = [];
  for (let h = loHundred; h <= hiHundred; h++) {
    likePatterns.push(`upper(incident_address) like '${h}__ ${escapedStreet}%'`);
    if (h < 10) likePatterns.push(`upper(incident_address) like '${h}_ ${escapedStreet}%'`);
  }

  const base = 'https://data.cityofnewyork.us/resource/erm2-nwe9.json';
  const whereClause = `complaint_type like '%Noise%' AND created_date >= '2021-01-01' AND (${likePatterns.join(' OR ')})`;
  const params = new URLSearchParams({
    '$where': whereClause,
    '$order': 'created_date DESC',
    '$limit': String(limit)
  });

  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
  try {
    const res = await fetch(`${base}?${params.toString()}`, { signal: controller.signal });
    clearTimeout(timer);
    if (!res.ok) return [];
    const allRows = await res.json();
    // Final client-side filter to exact ±50 range
    const filtered = allRows.filter(r => {
      if (!r.incident_address) return false;
      const num = parseInt(r.incident_address.split(' ')[0], 10);
      return !isNaN(num) && num >= lo && num <= hi;
    });
    return { rows: filtered, lo, hi };
  } catch (err) {
    clearTimeout(timer);
    return { rows: [], lo, hi };
  }
}

// How long to wait for the NYC Open Data API before giving up.
// 15s is long enough for large result sets on slow connections,
// but short enough that users don't think the app is frozen.
const FETCH_TIMEOUT_MS = 180000; // 3 minutes — let the API take its time

async function fetchNoiseRows(streetLike, houseNumber) {
  const base = 'https://data.cityofnewyork.us/resource/erm2-nwe9.json';
  const params = new URLSearchParams({
    '$where': `(${buildWhere(streetLike, houseNumber)}) AND created_date >= '2021-01-01'`,
    '$order': 'created_date DESC',
    '$limit': '5000'
  });

  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);

  try {
    const res = await fetch(`${base}?${params.toString()}`, { signal: controller.signal });
    clearTimeout(timer);
    if (!res.ok) {
      const text = await res.text().catch(() => '');
      throw new Error(`NYC Open Data returned ${res.status}${text ? ': ' + text.slice(0, 150) : ''}`);
    }
    return res.json();
  } catch (err) {
    clearTimeout(timer);
    if (err.name === 'AbortError') {
      throw new Error('TIMEOUT');
    }
    throw err;
  }
}


async function fetchBoroughSample(borough) {
  // Query borough-wide over a 3-month window, annualized to /year on both sides,
  // so the comparison is apples-to-apples without the cost of a full 12-month borough scan.
  // Addresses with only 1 complaint are excluded (HAVING count >= 2) to filter one-off noise
  // and keep the pool meaningful. Limit 1000 is statistically solid for a percentile.
  if (!borough) return [];
  const base = 'https://data.cityofnewyork.us/resource/erm2-nwe9.json';
  const escapedBorough = borough.replace(/'/g, "''");
  const BOROUGH_WINDOW_MONTHS = 3;
  const cutoff = new Date();
  cutoff.setMonth(cutoff.getMonth() - BOROUGH_WINDOW_MONTHS);
  const cutoffIso = cutoff.toISOString().split('T')[0];
  const params = new URLSearchParams({
    '$select': 'incident_address, count(*) as cnt',
    '$where': `complaint_type like '%Noise%' AND created_date >= '${cutoffIso}' AND upper(borough) = '${escapedBorough.toUpperCase()}'`,
    '$group': 'incident_address',
    '$having': 'count(*) >= 2',
    '$limit': '1000'
  });
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
  try {
    const res = await fetch(`${base}?${params.toString()}`, { signal: controller.signal });
    clearTimeout(timer);
    if (!res.ok) return [];
    return res.json();
  } catch (err) {
    clearTimeout(timer);
    return [];
  }
}

function computeBoroughPercentile(perYear, boroughRows) {
  if (!boroughRows || boroughRows.length < 10) return null;
  // Borough rows cover 3 months — annualize to /year (÷ 3/12 = × 4) so the
  // rate is on the same scale as perYear (which is already complaints/year).
  const BOROUGH_WINDOW_YEARS = 3 / 12;
  const rates = boroughRows
    .map(r => parseInt(r.cnt, 10) / BOROUGH_WINDOW_YEARS)
    .filter(v => isFinite(v) && v >= 0)
    .sort((a, b) => a - b);

  const position = rates.filter(r => r <= perYear).length;
  return Math.round((position / rates.length) * 100);
}

function boroughScoreLabel(percentile, borough) {
  if (percentile === null) return null;
  const name = borough ? borough.charAt(0) + borough.slice(1).toLowerCase() : 'this borough';
  if (percentile <= 25)  return { word: 'Quiet',                sub: `Bottom 25% of ${name}`,        pctLabel: `Bottom 25% of ${name}`,                 cls: 'quiet' };
  if (percentile <= 50)  return { word: 'Fairly Quiet',         sub: `Below average for ${name}`,    pctLabel: `Below average for ${name}`,             cls: 'quiet' };
  if (percentile <= 80)  return { word: 'Average',              sub: `Around the ${name} average`,   pctLabel: `${percentile}th percentile in ${name}`, cls: 'moderate' };
  if (percentile <= 95)  return { word: 'Loud',                 sub: `Top 20% of ${name}`,           pctLabel: `${percentile}th percentile in ${name}`, cls: 'loud' };
  return                        { word: 'Very Loud',            sub: `Top 5% of ${name}`,            pctLabel: `Top 5% of ${name}`,                     cls: 'loud' };
}

function toggleAccordion(header) {
  const section = header.closest('.accordion-section');
  const body = section.querySelector('.accordion-body');
  const isOpen = section.classList.contains('open');
  if (isOpen) {
    section.classList.remove('open');
    body.classList.remove('open');
  } else {
    section.classList.add('open');
    body.classList.add('open');
    // Wait for transition to begin, then scroll header into view
    setTimeout(() => {
      header.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 150);
  }
}

// ---- Mobile nav & CTA ----
const mobileNav = document.getElementById('mobileNav');
const newSearchBtn = document.getElementById('newSearchBtn');
const mobileCta = document.getElementById('mobileCta');

function isMobile() { return window.innerWidth <= 600; }

// Show mobile CTA button on load if mobile
function initMobile() {
  if (isMobile()) {
    mobileCta.style.display = 'block';
  } else {
    mobileCta.style.display = 'none';
  }
}
initMobile();
window.addEventListener('resize', initMobile);

// Mobile CTA triggers the same search as Check button
mobileCta.addEventListener('click', () => {
  hideSuggestions();
  runSearch(addressInput.value);
});

// New search: clear result, hide nav, show landing
newSearchBtn.addEventListener('click', () => {
  resultArea.innerHTML = '';
  document.getElementById('boroughCta').style.display = 'none';
  document.getElementById('heroSection').classList.remove('has-results');
  document.getElementById('heroSection').classList.remove('map-showing');
  document.body.classList.remove('map-showing-body');
  document.getElementById('landingBoroughCta').style.display = 'block';
  mobileNav.classList.remove('visible');
  if (isMobile()) {
    mobileCta.style.display = 'block';
  }
  addressInput.value = '';
  addressInput.focus();
  btn.disabled = false;
});

async function runSearch(address, geoMeta) {
  const resultArea = document.getElementById('resultArea');
  const btn = document.getElementById('searchBtn');
  const cleaned = address.trim();

  if (!cleaned) return;

  // Always hide the borough map and both CTAs when an address search runs
  document.getElementById('boroughMapView').style.display = 'none';
  document.getElementById('landingBoroughCta').style.display = 'none';
  document.getElementById('boroughCta').style.display = 'none';
  document.getElementById('heroSection').classList.remove('map-showing');
  document.body.classList.remove('map-showing-body');

  const parsed = parseAddress(cleaned);

  const STEPS = [
    { id: 'parse',    label: 'Reading address',                        time: null          },
    { id: 'address',  label: 'Pulling 311 noise reports for this address',  time: '~10–25 sec · scanning 4.9M records'    },
    { id: 'borough',  label: 'Pulling borough percentile data',        time: '~5–10 sec · sampling 1,000 addresses'   },
    { id: 'score',    label: 'Calculating label & trend',              time: null          },
    { id: 'building', label: 'Building your report',                   time: null          },
  ];
  const PCT = { parse: 10, address: 40, borough: 65, score: 85, building: 95, complete: 100 };

  const CHECK_SVG = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3 8.5L6.5 12L13 5" stroke="#c0392b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`;

  const SPIN_SVG = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="6" stroke="#ddd6c8" stroke-width="1.8"/>
    <path d="M8 2A6 6 0 0 1 14 8" stroke="#15130f" stroke-width="1.8" stroke-linecap="round"/>
  </svg>`;

  const DOT_SVG = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="3" fill="#ccc5b5"/>
  </svg>`;

  function renderProgress(activeId, address, labelOverride, eta) {
    const pct = PCT[activeId] || 0;
    const stepId = activeId === 'complete' ? 'building' : activeId;
    const pctIds = Object.keys(PCT);
    const activeIdx = pctIds.indexOf(stepId);
    const defaultLabel = STEPS.find(s => s.id === stepId)?.label || '';
    const headlineLabel = labelOverride || defaultLabel;
    const etaText = eta || '';

    const stepsHtml = STEPS.map((s, i) => {
      const sIdx = pctIds.indexOf(s.id);
      const isDone = sIdx < activeIdx;
      const isActive = s.id === stepId;
      const cls = isDone ? 'done' : isActive ? 'active' : '';
      const timeHint = s.time ? ` <span class="progress-step-time">${s.time}</span>` : '';
      const displayLabel = (isActive && labelOverride) ? labelOverride : (isDone && stepDoneLabels[s.id]) ? stepDoneLabels[s.id] : s.label;
      const icon = isDone
        ? `<span class="progress-step-icon">${CHECK_SVG}</span>`
        : isActive
          ? `<span class="progress-step-icon spin">${SPIN_SVG}</span>`
          : `<span class="progress-step-icon">${DOT_SVG}</span>`;
      return `<div class="progress-step-item ${cls}">${icon}<span>${displayLabel}${(isActive || isDone) ? timeHint : ''}</span></div>`;
    }).join('');

    resultArea.innerHTML = `
      <div class="progress-wrap">
        <p class="progress-address">${escapeHtml(address)}</p>
        <div class="progress-step-label">
          <span class="progress-step-text">${headlineLabel}</span>
          <span class="progress-step-pct">${pct}%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" style="width: ${pct}%"></div>
        </div>
        <div class="progress-steps-list">${stepsHtml}</div>
        <p class="progress-eta">${etaText}</p>
      </div>`;
  }

  btn.disabled = true;
  // Collapse hero and show results directly below search bar
  document.getElementById('heroSection').classList.add('has-results');
  // Show nav bar on all screen sizes after search
  mobileNav.classList.add('visible');
  if (isMobile()) {
    mobileCta.style.display = 'none';
  }
  // Hide borough CTA until results are ready
  document.getElementById('boroughCta').style.display = 'none';
  renderProgress('parse', cleaned);

  // Cycle bottom ETA copy every 20s to reassure user during long queries
  const ETA_MESSAGES = [
    '',
    'Still working — NYC Open Data can be slow during peak hours.',
    'Large datasets take time — almost there.',
    'Nearly done — thanks for your patience.',
  ];
  let etaIndex = 0;
  const etaInterval = setInterval(() => {
    etaIndex = Math.min(etaIndex + 1, ETA_MESSAGES.length - 1);
    const etaEl = resultArea.querySelector('.progress-eta');
    if (etaEl) etaEl.textContent = ETA_MESSAGES[etaIndex];
  }, 20000);

  // Track label overrides per step so they persist when steps become 'done'
  let addressStepLabel = 'Pulling 311 noise reports for this address';
  const stepDoneLabels = {};

  try {
    // Fire borough comparison query in parallel — resolves within the 5s minimum wait
    let boroughSamplePromise = Promise.resolve([]);

    // Fire exact + block queries simultaneously and await both at once.
    // Use exact if it has results, otherwise use block — zero extra wait either way.
    renderProgress('address', cleaned, addressStepLabel);

    // Race exact vs block: if exact returns first with results, we use it immediately.
    // If exact is empty, we wait for block. Block query is aborted if exact wins.
    const blockAbort = new AbortController();
    const exactRows = await fetchNoiseRows(parsed.street, parsed.houseNumber);
    let blockRows = [];
    let blockLo = null, blockHi = null;
    if (exactRows.length === 0 && parsed.houseNumber) {
      const blockResult = await fetchBlockRows(parsed.street, parsed.houseNumber, 500);
      blockRows = blockResult.rows;
      blockLo = blockResult.lo;
      blockHi = blockResult.hi;
    }

    let rows = [];
    let matchMode = 'exact';

    if (exactRows.length > 0) {
      rows = exactRows;
      matchMode = 'exact';
    } else if (blockRows.length > 0) {
      rows = blockRows;
      matchMode = 'block';
      addressStepLabel = 'No exact match — showing complaints from this block';
      stepDoneLabels['address'] = addressStepLabel;
      renderProgress('address', cleaned, addressStepLabel);
    }

    // Pass 3: full street fallback only if both exact and block failed
    if (rows.length === 0 && parsed.houseNumber) {
      addressStepLabel = 'No exact match — searching the full street';
      stepDoneLabels['address'] = addressStepLabel;
      renderProgress('address', cleaned, addressStepLabel);
      rows = await fetchNoiseRows(parsed.street, null);
      if (rows.length > 0) matchMode = 'street-only';
    }

    if (rows.length === 0) {

      resultArea.innerHTML = `
        <div class="state">
          No noise complaints found for "${escapeHtml(cleaned)}" since 2021.<br>
          <span style="font-size:0.82rem">Try just the street name (drop the house number). NYC 311 addresses don't always match exactly.</span>
        </div>`;
      btn.disabled = false;
      return;
    }

    const matchedAddress = matchMode === 'exact'
      ? (rows[0].incident_address || cleaned)
      : parsed.street;

    // Label shown below the address kicker based on match mode.
    // If a street-only match hit the 5,000 row API cap, flag it as unreliable.
    const hitStreetCap = matchMode === 'street-only' && rows.length >= 5000;
    const blockRangeLabel = blockLo !== null && blockHi !== null
      ? `No exact match · showing complaints from ${blockLo}–${blockHi} ${parsed.street}`
      : 'No exact match · showing complaints on this block';
    const matchLabel = matchMode === 'exact'
      ? null
      : matchMode === 'block'
        ? blockRangeLabel
        : hitStreetCap
          ? 'No exact match · street-wide data hit the API limit (5,000 rows) — results may be incomplete or too broad to be meaningful for a single address'
          : 'No exact match · showing all complaints on this street';

    // Rolling 12-month scoring window — defined first so SCORE_CUTOFF_ISO is available
    // before the borough fetch fires below.
    const SCORE_CUTOFF = new Date();
    SCORE_CUTOFF.setFullYear(SCORE_CUTOFF.getFullYear() - 1);
    const SCORE_CUTOFF_ISO = SCORE_CUTOFF.toISOString().split('T')[0];
    const cutoffLabel = SCORE_CUTOFF.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    // Extract borough from first row and kick off the parallel borough sample.
    const borough = rows[0]?.borough || null;

    // Session cache: borough distribution doesn't change meaningfully within a session,
    // so reuse it for repeat searches in the same borough.
    const cacheKey = `boroughSample:${borough}`;
    let cachedSample = null;
    try { const raw = sessionStorage.getItem(cacheKey); if (raw) cachedSample = JSON.parse(raw); } catch(e) {}
    if (cachedSample) {
      boroughSamplePromise = Promise.resolve(cachedSample);
    } else {
      boroughSamplePromise = fetchBoroughSample(borough).then(data => {
        try { sessionStorage.setItem(cacheKey, JSON.stringify(data)); } catch(e) {}
        return data;
      });
    }

    const oldestDate = rows[rows.length - 1].created_date;
    const newestDate = rows[0].created_date;
    const yearsSpan = oldestDate ? Math.max(1, (new Date() - new Date(oldestDate)) / (1000 * 60 * 60 * 24 * 365)) : 1;
    const perYear = rows.length / yearsSpan;
    const perYearDisplay = Math.round(perYear);

    // Score is based on the last 12 months — most relevant for current housing decisions.
    const recentRows = rows.filter(r => r.created_date && new Date(r.created_date) >= SCORE_CUTOFF);
    const recentYears = 1;
    const recentPerYear = recentRows.length / recentYears;

    // Await borough comparison (fired in parallel earlier).
    // 3-month borough window annualized to /year — apples-to-apples with recentPerYear.
    renderProgress('borough', cleaned);
    const boroughRows = await boroughSamplePromise;
    const boroughPercentile = computeBoroughPercentile(recentPerYear, boroughRows);
    const boroughScore = boroughPercentile !== null
      ? boroughScoreLabel(boroughPercentile, borough)
      : null;

    // Fall back to fixed thresholds if borough data unavailable
    // Both score paths use recentPerYear (last 12 months, annualized to /year) for consistency
    const score = boroughScore || scoreFromPerYear(recentPerYear);



    const typeCounts = {};
    rows.forEach(r => {
      const t = r.complaint_type || 'Unknown';
      typeCounts[t] = (typeCounts[t] || 0) + 1;
    });
    const sortedTypes = Object.entries(typeCounts).sort((a, b) => b[1] - a[1]).slice(0, 6);
    const maxTypeCount = rows.length || 1;

    // Store all recent rows (capped at 50) for load-more pagination
    const RECENT_PAGE_SIZE = 5;
