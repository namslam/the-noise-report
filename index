    const peakTopEntry = Object.entries(peakTypeMap).sort((a, b) => b[1] - a[1])[0];
    const peakTopLabel = peakTopEntry ? labelFor(peakTopEntry[0]) : null;
    const peakTopCount = peakTopEntry ? peakTopEntry[1] : 0;
