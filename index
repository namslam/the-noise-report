const BOROUGH_DISPLAY_NAMES = {
  'BRONX':         'The Bronx',
  'BROOKLYN':      'Brooklyn',
  'MANHATTAN':     'Manhattan',
  'QUEENS':        'Queens',
  'STATEN ISLAND': 'Staten Island'
};

// Color scale: light pink → dark red (quietest → loudest)
const COLOR_SCALE = ['#f6dcd2', '#e8a48d', '#d9694a', '#b5341a', '#7c1d0e'];

function boroughColor(rank, total) {
  // rank 0 = loudest, rank total-1 = quietest
  const idx = Math.round((rank / (total - 1)) * (COLOR_SCALE.length - 1));
  return COLOR_SCALE[COLOR_SCALE.length - 1 - idx];
}

